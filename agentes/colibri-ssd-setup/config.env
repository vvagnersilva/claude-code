# =============================================================================
# colibri-ssd-setup — configuration
# -----------------------------------------------------------------------------
# Nothing is hardcoded in the scripts; every tunable lives here.
# To override without editing this file (kept in git), copy it to
# `config.local.env` and change values there — the scripts load the local copy
# last, so it wins.
#
# All values are verified against the real Colibrì README / launcher
# (github.com/JustVugg/colibri) as of 2026-07-14. See README.md.
# =============================================================================

# --- External SSD -----------------------------------------------------------
# Volume name of the external NVMe SSD. Expected mount point is
# <mount-root>/$VOLUME_NAME, where the mount root is resolved per OS:
#   macOS /Volumes · Linux /run/media/$USER or /media/$USER · WSL /mnt
# Recommended: format the SSD APFS (macOS) / ext4 (Linux) with exactly this name.
VOLUME_NAME="AI_DRIVE"

# Full mount path override. Leave empty to auto-resolve as above. Set this when
# the drive mounts somewhere non-standard (e.g. MOUNT_POINT="/mnt/ai_drive").
MOUNT_POINT=""

# Linux only: accept a target drive that is NOT detected as external/hot-plug.
# Linux desktops often stream from a big *internal* secondary NVMe — that's
# fine THERE (never needed on macOS; the boot disk is still always refused).
# 0 = require external (safe default), 1 = allow a dedicated internal drive.
ALLOW_INTERNAL_TARGET=0

# Accept slow/corruption-prone filesystems (exfat/ntfs/vfat/drvfs) instead of
# refusing. Expert streaming on these is painful; override at your own risk.
ALLOW_SLOW_FS=0

# Minimum free space (GB) required on the SSD before downloading the model.
# The int4 container is ~372 GB; 400 GB leaves headroom for the .cache/ metadata
# HF writes next to --local-dir, plus the engine clone and KV/usage files.
MIN_FREE_GB=400

# Sequential WRITE speed floor (MB/s). Below this the drive is almost certainly
# USB 3.0 / SATA and expert streaming will be painfully slow. TB3/TB4 or USB4
# NVMe enclosures deliver ~1500-2800 MB/s and are what the project's fast
# datapoints use. This is a WARNING threshold, not a hard stop.
MIN_WRITE_MBPS=700

# --- RAM budget -------------------------------------------------------------
# Passed to the engine as `--ram N`. The expert LRU cache auto-sizes to fill
# this budget. Minimum supported is 16. Give it as much free RAM as you can
# spare WITHOUT pushing the machine into swap (swap writes wear the SSD).
# "auto" = total RAM minus OS headroom (~8 GB; e.g. 24 GB machine -> 16,
# 128 GB machine -> 120). Or set an integer to pin it.
RAM_GB="auto"

# --- Model ------------------------------------------------------------------
# VERIFIED: this is the community clone with int8 MTP heads (matey-0 / mateogrgic).
# Do NOT switch to jlnsrk/GLM-5.2-colibri-int4 — that original mirror ships int4
# MTP heads and speculative decoding silently stays at 0% acceptance.
MODEL_REPO="mateogrgic/GLM-5.2-colibri-int4-with-int8-mtp"

# Sub-directory name (under $VOLUME/colibri/models) the model is downloaded into.
MODEL_DIR="GLM-5.2-colibri-int4-with-int8-mtp"

# --- Colibrì engine ---------------------------------------------------------
COLIBRI_REPO_URL="https://github.com/JustVugg/colibri.git"

# --- Runtime toggles --------------------------------------------------------
# Metal backend (Apple Silicon only). "auto" = build & use it on arm64 Macs,
# fall back to CPU if the Metal build fails. "yes"/"no" force it.
ENABLE_METAL="auto"

# CUDA backend (Linux/WSL with an NVIDIA GPU). "auto" = build `make glm CUDA=1`
# when nvidia-smi is present; failure is non-fatal (CPU build stays).
ENABLE_CUDA="auto"

# Router-lookahead prefetch (PILOT=1). VERIFIED real but EXPERIMENTAL: measured
# neutral on disk-bound boxes, may help when compute and disk are balanced.
# 0 = off (default), 1 = on.
ENABLE_PILOT=0

# Use hf_transfer (Rust, multi-threaded, much faster HF downloads). 1 = on.
HF_TRANSFER=1
